{
  "name": "repo",
  "private": true,
  "scripts": {
    "build": "turbo run build --env-mode=loose",
    "dev": "dotenv -- turbo run dev --env-mode=loose --filter=web",
    "dev-mobile": "dotenv -- turbo run dev --env-mode=loose --filter=mobile",
    "lint": "turbo run lint --env-mode=loose",
    "compile": "turbo run compile && pnpm i",
    "tsc": "turbo run tsc"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  }
}
